# Frontend production env — set these in the Vercel project settings
# (Project -> Settings -> Environment Variables), not in a committed file.

# Public API base — your deployed gateway behind Caddy (HTTPS, no trailing slash).
NEXT_PUBLIC_API_URL=https://api.example.com

# Restaurant shown in the consumer app (the seeded "La Tablero Bistro").
NEXT_PUBLIC_RESTAURANT_ID=22222222-0000-0000-0000-000000000001

# Stripe publishable key (test key for a demo). Must match the PaymentService Stripe keys.
NEXT_PUBLIC_STRIPE_KEY=pk_test_...
