{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:8080",

  "Service": { "Name": "identity", "Port": "8080" },
  "ApplyMigrationsOnStartup": true,

  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=identity_db;Username=bite;Password=bite",
    "RabbitMq": "amqp://bite:bite@localhost:5672",
    "Redis":    "localhost:6379",
    "Consul":   "http://localhost:8500"
  },

  "Jwt": {
    "Issuer": "bite-identity",
    "Audience": "bite-clients",
    "SigningKey": "dev-signing-key-change-in-production-256-bits-min!!",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },

  "OpenTelemetry": { "OtlpEndpoint": "http://localhost:4317" }
}
