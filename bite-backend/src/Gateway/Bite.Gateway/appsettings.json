{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:8080",

  "Jwt": {
    "Issuer": "bite-identity",
    "Audience": "bite-clients",
    "SigningKey": "dev-signing-key-change-in-production-256-bits-min!!"
  },

  "ReverseProxy": {
    "Routes": {
      "identity-public": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/identity/auth/{**catch-all}" }
      },
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/identity/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "restaurant-public": {
        "ClusterId": "restaurant",
        "Match": { "Path": "/api/restaurant/public/{**catch-all}" }
      },
      "restaurant": {
        "ClusterId": "restaurant",
        "Match": { "Path": "/api/restaurant/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "reservations": {
        "ClusterId": "reservation",
        "Match": { "Path": "/api/reservations/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "tables": {
        "ClusterId": "reservation",
        "Match": { "Path": "/api/tables/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "orders": {
        "ClusterId": "orderkitchen",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "kitchen": {
        "ClusterId": "orderkitchen",
        "Match": { "Path": "/api/kitchen/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "menu": {
        "ClusterId": "orderkitchen",
        "Match": { "Path": "/api/menu/{**catch-all}" }
      },
      "kitchen-hub": {
        "ClusterId": "orderkitchen",
        "Match": { "Path": "/hubs/kitchen/{**catch-all}" }
      },
      "waiter-hub": {
        "ClusterId": "orderkitchen",
        "Match": { "Path": "/hubs/waiter/{**catch-all}" }
      },
      "table-hub": {
        "ClusterId": "orderkitchen",
        "Match": { "Path": "/hubs/table/{**catch-all}" }
      },
      "payments": {
        "ClusterId": "payment",
        "Match": { "Path": "/api/payments/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "stripe-webhook": {
        "ClusterId": "payment",
        "Match": { "Path": "/api/payments/webhook/stripe" }
      },
      "cashier-hub": {
        "ClusterId": "payment",
        "Match": { "Path": "/hubs/cashier/{**catch-all}" }
      },
      "delivery": {
        "ClusterId": "delivery",
        "Match": { "Path": "/api/delivery/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "courier-hub": {
        "ClusterId": "delivery",
        "Match": { "Path": "/hubs/courier/{**catch-all}" }
      },
      "notifications": {
        "ClusterId": "notification",
        "Match": { "Path": "/api/notify/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "reviews": {
        "ClusterId": "notification",
        "Match": { "Path": "/api/reviews/{**catch-all}" }
      },
      "notify-hub": {
        "ClusterId": "notification",
        "Match": { "Path": "/hubs/notify/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity":     { "Destinations": { "d1": { "Address": "http://identity:8080/" } } },
      "restaurant":   { "Destinations": { "d1": { "Address": "http://restaurant:8080/" } } },
      "reservation":  { "Destinations": { "d1": { "Address": "http://reservation:8080/" } } },
      "orderkitchen": { "Destinations": { "d1": { "Address": "http://orderkitchen:8080/" } } },
      "payment":      { "Destinations": { "d1": { "Address": "http://payment:8080/" } } },
      "delivery":     { "Destinations": { "d1": { "Address": "http://delivery:8080/" } } },
      "notification": { "Destinations": { "d1": { "Address": "http://notification:8080/" } } }
    }
  }
}
